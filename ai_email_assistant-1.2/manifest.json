{
  "manifest_version": 3,
  "name": "AI Email Assistant",
  "version": "1.2",
  "description": "This extension automates email workflows efficiently.",
  "permissions": [
    "storage",
    "identity",
    "tabs",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://mail.google.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://mail.google.com/*"
      ],
      "js": [
        "content.js"
      ]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "icons/*"
      ],
      "matches": [
        "https://mail.google.com/*"
      ]
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "ai-email-assistant-unique123@yourdomain.com"
    }
  }
}
